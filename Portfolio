<!-- MODAL -->
<div class="modal-overlay" id="modal">
  <div class="modal-box">
    <div class="modal-video" id="modalVideo">
      <span>Embed del video aquí</span>
    </div>
    <div class="modal-info">
      <button class="modal-close" onclick="closeModal()">×</button>
      <div class="modal-title" id="modalTitle">Proyecto</div>
      <div style="font-size:0.75rem; color:var(--gray-muted); letter-spacing:0.1em; text-transform:uppercase;" id="modalType">Contenido para redes</div>
    </div>
  </div>
</div>

<script>
  /*
    ✏️ CÓMO PERSONALIZAR TUS PROYECTOS:
    - Reemplazá "Proyecto 01" con el nombre real de cada video
    - En "url", pegá el link embed de YouTube (formato: https://www.youtube.com/embed/VIDEO_ID)
      o de Vimeo (formato: https://player.vimeo.com/video/VIDEO_ID)
    - En "thumb", podés poner la URL de una imagen thumbnail (opcional)
  */
  const projects = [
    { name: "Proyecto 01", type: "Contenido para redes", url: "", thumb: "" },
    { name: "Proyecto 02", type: "Contenido para redes", url: "", thumb: "" },
    { name: "Proyecto 03", type: "Contenido para redes", url: "", thumb: "" },
    { name: "Proyecto 04", type: "Contenido para redes", url: "", thumb: "" },
    { name: "Proyecto 05", type: "Contenido para redes", url: "", thumb: "" },
    { name: "Proyecto 06", type: "Contenido para redes", url: "", thumb: "" },
  ];

  const grid = document.getElementById('projectsGrid');

  projects.forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'project-card';
    const num = String(i + 1).padStart(2, '0');
    const thumbContent = p.thumb
      ? `<img src="${p.thumb}" alt="${p.name}" style="width:100%;height:100%;object-fit:cover;">`
      : `<div class="thumb-placeholder">
           <div class="thumb-num">${num}</div>
           <div class="play-btn"><div class="play-icon"></div></div>
         </div>`;
    card.innerHTML = `
      ${thumbContent}
      <div class="project-overlay">
        <div class="project-name">${p.name}</div>
        <div class="project-type">${p.type}</div>
      </div>
    `;
    card.addEventListener('click', () => openModal(p));
    grid.appendChild(card);
  });

  function openModal(p) {
    document.getElementById('modalTitle').textContent = p.name;
    document.getElementById('modalType').textContent = p.type;
    const mv = document.getElementById('modalVideo');
    if (p.url) {
      mv.innerHTML = `<iframe src="${p.url}" frameborder="0" allowfullscreen allow="autoplay; encrypted-media"></iframe>`;
    } else {
      mv.innerHTML = `<span>Embed del video aquí</span>`;
    }
    document.getElementById('modal').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    document.getElementById('modal').classList.remove('open');
    document.getElementById('modalVideo').innerHTML = '';
    document.body.style.overflow = '';
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });
</script>
</body>
</html>
