<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nacho — Video Editor</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --purple-dark: #1a0a2e;
    --purple-deep: #2d1057;
    --purple-mid: #6b21a8;
    --purple-bright: #a855f7;
    --purple-light: #d8b4fe;
    --purple-glow: #e9d5ff;
    --indigo: #4f46e5;
    --white: #ffffff;
    --off-white: #f8f5ff;
    --gray-light: #c4b5d4;
    --gray-muted: #7c6f8a;
    --bg-card: rgba(255,255,255,0.04);
    --border-subtle: rgba(168,85,247,0.15);
    --border-mid: rgba(168,85,247,0.3);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--purple-dark);
    color: var(--white);
    overflow-x: hidden;
  }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 4rem;
    background: rgba(26,10,46,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, var(--white) 0%, var(--purple-light) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .nav-links { display: flex; gap: 2.5rem; }
  .nav-links a {
    color: var(--gray-light); font-size: 0.85rem; letter-spacing: 0.08em;
    text-transform: uppercase; text-decoration: none;
    transition: color 0.3s;
  }
  .nav-links a:hover { color: var(--purple-bright); }

  #hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 40%, rgba(107,33,168,0.35) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(79,70,229,0.2) 0%, transparent 60%),
      radial-gradient(ellipse 30% 30% at 80% 20%, rgba(168,85,247,0.15) 0%, transparent 60%);
  }
  .hero-line {
    position: absolute;
    width: 1px; height: 120px;
    background: linear-gradient(to bottom, transparent, var(--purple-bright), transparent);
    top: 0; left: 50%;
  }
  .hero-tag {
    position: relative; z-index: 1;
    font-size: 0.75rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--purple-bright);
    border: 1px solid var(--border-mid);
    padding: 0.4rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    background: rgba(168,85,247,0.08);
  }
  .hero-name {
    position: relative; z-index: 1;
    font-family: 'Playfair Display', serif;
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--white) 30%, var(--purple-light) 70%, var(--purple-bright) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 1.5rem;
  }
  .hero-tagline {
    position: relative; z-index: 1;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--gray-light);
    font-weight: 300;
    letter-spacing: 0.03em;
    max-width: 500px;
    line-height: 1.6;
    margin-bottom: 3rem;
  }
  .hero-tagline em { color: var(--purple-light); font-style: italic; }
  .hero-cta {
    position: relative; z-index: 1;
    display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;
  }
  .btn-primary {
    padding: 0.85rem 2.2rem;
    background: linear-gradient(135deg, var(--purple-mid), var(--indigo));
    color: var(--white); border: none;
    border-radius: 100px; font-size: 0.9rem;
    letter-spacing: 0.05em; cursor: pointer;
    text-decoration: none;
    transition: opacity 0.3s, transform 0.2s;
    box-shadow: 0 0 30px rgba(107,33,168,0.4);
  }
  .btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }
  .btn-outline {
    padding: 0.85rem 2.2rem;
    background: transparent;
    color: var(--purple-light);
    border: 1px solid var(--border-mid);
    border-radius: 100px; font-size: 0.9rem;
    letter-spacing: 0.05em; cursor: pointer;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
  }
  .btn-outline:hover { background: rgba(168,85,247,0.1); transform: translateY(-2px); }
  .scroll-indicator {
    position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
    z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    color: var(--gray-muted); font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
  }
  .scroll-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--purple-bright), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100% { opacity:0.3 } 50% { opacity:1 } }

  .section-header {
    display: flex; align-items: center; gap: 1.5rem;
    margin-bottom: 3.5rem;
  }
  .section-number {
    font-size: 0.7rem; color: var(--purple-bright);
    letter-spacing: 0.2em; text-transform: uppercase;
    white-space: nowrap;
  }
  .section-line { flex: 1; height: 1px; background: var(--border-subtle); }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    background: linear-gradient(135deg, var(--white), var(--purple-light));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
  }

  .projects-wrapper { max-width: 1100px; margin: 0 auto; padding: 0 4rem 6rem; }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .project-card {
    position: relative; overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
    cursor: pointer;
    transition: transform 0.3s, border-color 0.3s;
    aspect-ratio: 16/9;
  }
  .project-card:hover { transform: translateY(-4px); border-color: var(--border-mid); }
  .thumb-placeholder {
    width: 100%; height: 100%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.75rem;
    background: linear-gradient(135deg, rgba(107,33,168,0.3) 0%, rgba(26,10,46,0.8) 100%);
  }
  .thumb-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem; color: rgba(168,85,247,0.3);
    font-weight: 700;
  }
  .play-btn {
    width: 48px; height: 48px; border-radius: 50%;
    background: rgba(168,85,247,0.2);
    border: 1px solid var(--border-mid);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.3s;
  }
  .project-card:hover .play-btn { background: rgba(168,85,247,0.4); }
  .play-icon {
    width: 0; height: 0;
    border-top: 8px solid transparent;
    border-bottom: 8px solid transparent;
    border-left: 14px solid var(--purple-light);
    margin-left: 3px;
  }
  .project-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(26,10,46,0.9) 0%, transparent 50%);
    display: flex; flex-direction: column; justify-content: flex-end;
    padding: 1rem;
    opacity: 0; transition: opacity 0.3s;
  }
  .project-card:hover .project-overlay { opacity: 1; }
  .project-name { font-size: 0.85rem; font-weight: 500; color: var(--white); margin-bottom: 0.25rem; }
  .project-type { font-size: 0.7rem; color: var(--purple-light); letter-spacing: 0.1em; text-transform: uppercase; }

  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(10,5,20,0.92);
    align-items: center; justify-content: center;
    padding: 2rem;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    background: #1a0a2e;
    border: 1px solid var(--border-mid);
    border-radius: 16px;
    max-width: 800px; width: 100%;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(107,33,168,0.3);
  }
  .modal-video {
    width: 100%; aspect-ratio: 16/9;
    background: #0f0520;
    display: flex; align-items: center; justify-content: center;
    color: var(--gray-muted); font-size: 0.85rem;
  }
  .modal-video iframe { width: 100%; height: 100%; display: block; border: none; }
  .modal-info { padding: 1.5rem; }
  .modal-title { font-family: 'Playfair Display', serif; font-size: 1.3rem; margin-bottom: 0.5rem; }
  .modal-close {
    float: right; background: none; border: none;
    color: var(--gray-muted); font-size: 1.5rem; cursor: pointer;
    margin-top: -0.25rem;
    transition: color 0.2s;
  }
  .modal-close:hover { color: var(--white); }

  .clients-wrapper {
    max-width: 1100px; margin: 0 auto;
    padding: 5rem 4rem;
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }
  .clients-label {
    text-align: center;
    font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gray-muted); margin-bottom: 3rem;
  }
  .clients-grid {
    display: flex; flex-wrap: wrap;
    justify-content: center; align-items: center;
    gap: 1.5rem 3rem;
  }
  .client-item {
    padding: 1rem 2rem;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    background: var(--bg-card);
    transition: border-color 0.3s, background 0.3s;
    cursor: default;
    text-align: center;
  }
  .client-item:hover {
    border-color: var(--border-mid);
    background: rgba(168,85,247,0.07);
  }
  .client-name {
    font-size: 1rem; font-weight: 500;
    letter-spacing: 0.05em;
    background: linear-gradient(135deg, var(--white), var(--gray-light));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .client-type {
    font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--purple-bright); margin-top: 0.2rem;
  }

  .contact-wrapper {
    max-width: 1100px; margin: 0 auto;
    padding: 6rem 4rem; text-align: center;
  }
  .contact-tagline {
    color: var(--gray-light); font-weight: 300; font-size: 1.05rem;
    max-width: 400px; margin: 0 auto 3rem;
    line-height: 1.7;
  }
  .contact-links {
    display: flex; justify-content: center; gap: 1.5rem; flex-wrap: wrap;
  }
  .contact-link {
    display: flex; align-items: center; gap: 0.65rem;
    padding: 0.9rem 1.8rem;
    border: 1px solid var(--border-mid);
    border-radius: 100px;
    color: var(--purple-light);
    text-decoration: none; font-size: 0.85rem;
    letter-spacing: 0.05em;
    background: rgba(168,85,247,0.05);
    transition: background 0.3s, transform 0.2s;
  }
  .contact-link:hover { background: rgba(168,85,247,0.15); transform: translateY(-2px); }
  .contact-icon { width: 18px; height: 18px; fill: var(--purple-bright); flex-shrink: 0; }

  footer {
    text-align: center; padding: 2.5rem;
    border-top: 1px solid var(--border-subtle);
    color: var(--gray-muted); font-size: 0.75rem; letter-spacing: 0.1em;
  }
  footer span { color: var(--purple-bright); }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { gap: 1.5rem; }
    .projects-wrapper { padding: 0 1.5rem 4rem; }
    .projects-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    section, .clients-wrapper, .contact-wrapper { padding-left: 1.5rem; padding-right: 1.5rem; }
  }
  @media (max-width: 480px) {
    .projects-grid { grid-template-columns: 1fr; }
    .nav-links a { font-size: 0.75rem; }
  }
</style>
</head>
